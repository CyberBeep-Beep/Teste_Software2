{\n  "name": "pokeapi-qa-automation-framework",\n  "version": "1.0.0",\n  "description": "Comprehensive QA automation testing framework for PokéAPI with API and performance testing capabilities",\n  "main": "index.js",\n  "scripts": {\n    "test": "mocha tests/**/*.js --reporter json > reports/junit/test-results.json && mocha tests/**/*.js --reporter spec",\n    "test:api": "mocha tests/api/**/*.js --reporter spec",\n    "test:performance": "mocha tests/performance/**/*.js --reporter spec",\n    "test:all": "npm run test:api && npm run test:performance",\n    "report:generate": "allure generate reports/allure-results --clean -o reports/allure-report",\n    "report:open": "allure open reports/allure-report",\n    "lint": "eslint tests/**/*.js"\n  },\n  "keywords": [\n    "pokeapi",\n    "qa",\n    "automation",\n    "testing",\n    "api",\n    "performance"\n  ],\n  "author": "QA Team",\n  "license": "MIT",\n  "dependencies": {\n    "axios": "^1.6.5",\n    "chai": "^4.3.7",\n    "mocha": "^10.2.0",\n    "dotenv": "^16.0.3"\n  },\n  "devDependencies": {\n    "allure-mocha": "^2.13.42",\n    "eslint": "^8.36.0",\n    "mocha-junit-reporter": "^2.0.2",\n    "newman": "^5.3.2"\n  }\n}